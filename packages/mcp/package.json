{
  "name": "@dappql/mcp",
  "version": "0.1.2",
  "description": "MCP server exposing a DappQL project to AI coding agents — contract introspection, multicall reads, write simulation, and optional gated write execution.",
  "author": "DappQL Team",
  "type": "module",
  "bin": {
    "dappql-mcp": "./bin/dappql-mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dappql",
    "wagmi",
    "viem",
    "smart-contracts",
    "ai-agents",
    "claude",
    "cursor"
  ],
  "scripts": {
    "clean": "rm -rf ./node_modules && rm -rf ./dist && rm -rf ./.turbo",
    "dev": "pnpm exec tsc -b -w",
    "sync:docs": "node scripts/copy-library-reference.mjs",
    "prebuild": "pnpm run sync:docs",
    "build": "del-cli dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node ./bin/dappql-mcp.js",
    "version:bump": "bump patch --commit --push",
    "publish:npm": "pnpm publish --access public --no-workspace-root",
    "ship": "pnpm run build && pnpm run version:bump && pnpm run publish:npm --no-git-checks --access public"
  },
  "dependencies": {
    "@dappql/async": "workspace:*",
    "@dappql/codegen": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.4",
    "viem": "2.x"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "del-cli": "^6.0.0",
    "typescript": "^5.6.3",
    "viem": "^2.21.57",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dappql/monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/dappql/monorepo/issues"
  },
  "homepage": "https://github.com/dappql/monorepo#readme",
  "license": "MIT"
}
